{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "accounts-route": {
        "ClusterId": "accounts-cluster",
        "Match": {
          "Path": "/accounts/{**catch-all}"
        }
      },
      "bands-route": {
        "ClusterId": "bands-cluster",
        "Match": {
          "Path": "/bands/{**catch-all}"
        }
      },
      "bff-route": {
        "ClusterId": "bff-cluster",
        "Match": {
          "Path": "/bff/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5290"
          }
        }
      },
      "accounts-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5293"
          }
        }
      },
      "bands-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5081"
          }
        }
      },
      "bff-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5223"
          }
        }
      }
    }
  }
}
